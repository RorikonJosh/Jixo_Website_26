# Frontend (Vite) — baked in at build time; set these in Vercel → Settings → Environment Variables, then redeploy
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: force maintenance mode at build time (overrides DB setting when true)
# VITE_MAINTENANCE=false

# --- Supabase Edge Function secrets (set via Supabase CLI / Dashboard, NOT here) ---
# ADMIN_PASSWORD=your_admin_password
# RESEND_API_KEY=re_xxxx
# NOTIFY_EMAIL=jixo0407@gmail.com
# RESEND_FROM=Commission Form <onboarding@resend.dev>
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# SITE_ADMIN_URL=https://your-site.vercel.app/admin
